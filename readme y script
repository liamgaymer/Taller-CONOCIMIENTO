-- CREACIÓN DE LA BASE DE DATOS
CREATE DATABASE IF NOT EXISTS fashiondb;
USE fashiondb;
-- TABLA DISEÑADORES
CREATE TABLE Disenadores (
id_disenador INT PRIMARY KEY,
nombre_disenador VARCHAR(100)
);
-- TABLA PRENDAS (MÓDULO CENTRAL)
CREATE TABLE Prendas (
id_prenda INT PRIMARY KEY,
nombre VARCHAR(100),
categoria VARCHAR(50),
id_disenador INT,
CONSTRAINT fk_disenador FOREIGN KEY (id_disenador)
REFERENCES Disenadores(id_disenador)
);
-- TABLA MATERIALES
CREATE TABLE Materiales (
id_material INT PRIMARY KEY,
nombre_material VARCHAR(100),
composicion VARCHAR(255)
);
-- TABLA VENTAS
CREATE TABLE Ventas (
id_venta INT PRIMARY KEY,
tienda VARCHAR(100),
fecha_venta DATE,
monto DECIMAL(10, 2)
);
-- CONSULTA DE EJEMPLO: Ventas por monto descendente
SELECT * FROM Ventas ORDER BY monto DESC;
